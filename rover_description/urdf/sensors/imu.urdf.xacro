<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="imu_sensor" params="prefix topic parent_link">

    <gazebo reference="${parent_link}">
      <sensor name="${prefix}_imu_sensor" type="imu">
        <always_on>1</always_on>
        <update_rate>30</update_rate>
        <topic>${topic}</topic>
      </sensor>
    </gazebo>

  </xacro:macro>

</robot>