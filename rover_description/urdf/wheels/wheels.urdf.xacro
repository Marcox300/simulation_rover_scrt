<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="wheel" params="prefix parent_link num jx jy jz ox oy oz vx vy vz cx cy cz ix iy iz ixx iyy izz wheel_mass">

    <!--  WHEEL LINK  -->
    <link name="${prefix}_wheel_link">
      <visual>
        <origin rpy="${vx} ${vy} ${vz}" xyz="0.00000 0.00000 0.00000"/>
        <geometry>
          <mesh filename="package://rover_description/meshes/dae/Plane.${num}.dae" scale="1.00000 1.00000 1.00000"/>
        </geometry>
      </visual>

      <collision>
        <origin rpy="${cx} ${cy} ${cz}" xyz="0.00000 0.00000 0.00000"/>
        <geometry>
          <mesh filename="package://rover_description/meshes/dae/Plane.${num}.dae" scale="1.00000 1.00000 1.00000"/>
        </geometry>
        <surface>
        <friction>
          <ode>
            <mu>1.0</mu>
            <mu2>1.0</mu2>
            <fdir1>0 0 1</fdir1>
            <slip1>0.0</slip1>
            <slip2>0.0</slip2>
          </ode>
        </friction>
      </surface>
      </collision>

      <inertial>
        <mass value="${wheel_mass}"/>
        <inertia ixx="${ixx}" ixy="0.0" ixz="0.0"
                iyy="${iyy}" iyz="0.0"
                izz="${izz}"/>
        <origin rpy="${ix} ${iy} ${iz}" xyz="0.00000 0.00000 0.01491"/>
      </inertial>
    </link>

    <!--  WHEEL JOINT  -->
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="${parent_link}"/>
      <child link="${prefix}_wheel_link"/>
      <origin xyz="${jx} ${jy} ${jz}" rpy="${ox} ${oy} ${oz}"/>
      <axis xyz="0 0 1"/>
      <limit effort="500" velocity="20"/>
      <dynamics damping="0.05" friction="0.1"/>
    </joint>

    <transmission name="${prefix}_wheel_joint_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="${prefix}_wheel_joint" >
            <hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface>
        </joint>
        <actuator name="${prefix}_wheel_joint_motor">
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>

    <gazebo reference="${prefix}_wheel_link">
      <mu1>5</mu1>
      <mu2>5</mu2>
      <kp>2.75e6</kp>
      <kd>8.25e1</kd>
      <maxContacts>4</maxContacts>
    </gazebo>

  </xacro:macro>

</robot>